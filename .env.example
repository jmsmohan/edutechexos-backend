# Copy this file to .env and fill in your values
PORT=10002
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Optional — SMTP for password-reset emails (falls back to Ethereal test account if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EduTechExOS" <noreply@edutechex.in>
